# ============================================================
# SafeWatch AI — backend/.env
# Machine: Intel i7-4790 @ 3.6GHz + NVIDIA GeForce GPU + 16GB RAM
#
# KEY CHANGE vs i5-6500 profile:
#   DEVICE is now auto-detected from code (torch.cuda.is_available())
#   Remove or comment out DEVICE=cpu to let the GPU be used.
#   With GPU: YOLO ~2ms, CLIP ~5ms, FaceNet ~3ms (vs 18/150/25ms on CPU)
#   This frees 2 CPU cores and ~3GB RAM (models move to VRAM)
# ============================================================

# DO NOT set DEVICE=cpu — let it auto-detect the NVIDIA GPU
# DEVICE=cpu

# SQL debug OFF — saves ~5% CPU
DEBUG=false

# YOLO at 416px — catches seated/partial/far persons
# On GPU this is ~2ms (same as 320), so no penalty
IMG_SIZE=416

# YOLO confidence 0.35 — catches side-facing/seated/partial people
YOLO_CONFIDENCE=0.35

# Camera captures at 13fps (matches your IP camera hardware rate)
CAMERA_FPS=13
STREAM_FPS=13

# AI frame skips — much tighter with GPU:
# YOLO  every 2nd frame = ~6 detections/sec (was 3 on CPU)
# CLIP  every 10th frame = ~0.6/sec (was 30 on CPU — GPU CLIP is fast)
# Face  every 5th frame  = ~1.2/sec (was 15 on CPU)
DETECTION_FRAME_SKIP=2
ACTION_FRAME_SKIP=10
FACE_FRAME_SKIP=5

# Thread pools — GPU handles AI, more workers now fine
AI_POOL_WORKERS=4
IO_POOL_WORKERS=4

# JPEG quality 70 — i7 can handle it, better visual quality
JPEG_QUALITY=70

# Enable recording — i7+GPU can handle it
# Set to true if you want continuous footage saved
ENABLE_RECORDING=false

# CLIP inference mode
# false = auto-select (GPU→FP16, CPU+RAM≥4GB→FP32, CPU+low RAM→INT8)
# true  = force INT8 quantized CLIP on CPU (for very low-spec machines)
CLIP_LITE_MODE=false

# Stream downscale (1280 = cap at 720p, saves 3x encode time on 1920x1080)
# Set to 0 to send full resolution to browser
STREAM_MAX_WIDTH=1280

# AI processes frames 2s behind live (set lower with GPU, higher for slow CPU)
AI_LATENCY_SECONDS=2.0